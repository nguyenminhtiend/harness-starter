{
  "name": "@harness/example-web-studio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun --hot src/server/index.ts",
    "dev:ui": "bunx vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "start": "bun run src/server/index.ts"
  },
  "dependencies": {
    "@harness/agent": "workspace:*",
    "@harness/agents": "workspace:*",
    "@harness/core": "workspace:*",
    "@harness/hitl": "workspace:*",
    "@harness/llm-adapter": "workspace:*",
    "@harness/observability": "workspace:*",
    "@harness/session-events": "workspace:*",
    "@harness/session-store": "workspace:*",
    "@harness/tools": "workspace:*",
    "@harness/tools-mastra": "workspace:*",
    "@harness/workflows": "workspace:*",
    "@mastra/core": "1.27.0",
    "@mastra/libsql": "1.9.0",
    "@mastra/memory": "1.17.0",
    "@tanstack/react-query": "^5.0.0",
    "hono": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.0.0",
    "zod": "^4.0.0"
  },
  "optionalDependencies": {
    "@harness/mcp": "workspace:*",
    "@harness/memory-sqlite": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
