# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...

# Optional: override default model
# MODEL_ID=anthropic/claude-sonnet-4

# Optional: custom system prompt
# SYSTEM_PROMPT=You are a pirate assistant. Respond in pirate speak.

# --- Switching to Ollama ---
# 1. Install ollama-ai-provider:  bun add ollama-ai-provider
# 2. In src/provider.ts, replace the model line:
#
#    Before:
#      const model = openrouter.chat(config.MODEL_ID);
#
#    After:
#      import { ollama } from 'ollama-ai-provider';
#      const model = ollama(config.MODEL_ID);
#
# 3. Set MODEL_ID to an Ollama model name:
#      MODEL_ID=llama3.2
#
# 4. OPENROUTER_API_KEY is no longer needed (set to any non-empty value
#    or update the Zod schema in config.ts to make it optional).
