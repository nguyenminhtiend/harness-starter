{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/*.d.ts",
      "!**/bun.lock",
      "!**/.changeset",
      "!**/.harness",
      "!**/sample-ui"
    ]
  },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noForEach": "off"
      },
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error",
        "noUnusedFunctionParameters": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useBlockStatements": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error"
      },
      "suspicious": {
        "noConsole": "error",
        "noExplicitAny": "error"
      },
      "performance": {
        "noAccumulatingSpread": "warn",
        "noDelete": "warn"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/__tests__/**",
        "**/test/**",
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/e2e/**"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/core/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@harness/http": "core must not import http (DAG violation)",
                  "@harness/mastra": "core must not import mastra (DAG violation)"
                },
                "patterns": [
                  {
                    "group": ["@harness/http/*", "@harness/mastra/*"],
                    "message": "core must not import http/mastra (DAG violation)"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["packages/http/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@harness/mastra": "http must not import mastra (DAG violation)",
                  "@mastra/core": "http must not import runtime SDK directly (use core)"
                },
                "patterns": [
                  {
                    "group": [
                      "@harness/mastra/*",
                      "@mastra/core/*",
                      "@mastra/libsql",
                      "@mastra/libsql/*"
                    ],
                    "message": "http must not import capabilities/runtime SDK (DAG violation)"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/console/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@harness/core": "console may only import from @harness/http (DAG violation)",
                  "@harness/mastra": "console may only import from @harness/http (DAG violation)",
                  "@mastra/core": "console may only import from @harness/http (DAG violation)",
                  "@mastra/libsql": "console may only import from @harness/http (DAG violation)"
                },
                "patterns": [
                  {
                    "group": [
                      "@harness/core/*",
                      "@harness/mastra/*",
                      "@mastra/core/*",
                      "@mastra/libsql",
                      "@mastra/libsql/*"
                    ],
                    "message": "console may only import from @harness/http (DAG violation)"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/api/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@mastra/editor": "Editor is dev-only; mount in apps/studio",
                  "mastra": "Mastra CLI is dev-only; mount in apps/studio"
                },
                "patterns": [
                  {
                    "group": ["@mastra/editor/*"],
                    "message": "Editor is dev-only; mount in apps/studio"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/cli/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@mastra/editor": "Editor is dev-only; mount in apps/studio",
                  "mastra": "Mastra CLI is dev-only; mount in apps/studio"
                },
                "patterns": [
                  {
                    "group": ["@mastra/editor/*"],
                    "message": "Editor is dev-only; mount in apps/studio"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/studio/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@harness/http": "studio must not import http (DAG violation)",
                  "@harness/bootstrap": "studio must not import bootstrap; build its own Mastra instance",
                  "@harness/core": "studio uses Mastra primitives directly; core's Run aggregate is a runtime concern"
                },
                "patterns": [
                  {
                    "group": ["@harness/http/*", "@harness/bootstrap/*", "@harness/core/*"],
                    "message": "studio must only import from @harness/mastra (DAG violation)"
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["apps/console/src/components/HistorySidebar.tsx"],
      "linter": {
        "rules": {
          "a11y": {
            "useSemanticElements": "off"
          }
        }
      }
    }
  ]
}
