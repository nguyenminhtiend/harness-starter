# --- Provider API keys ---
GOOGLE_GENERATIVE_AI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# Ollama (local models — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Optional: override default model (prefix with provider)
# MASTRA_MODEL=google:gemini-2.5-flash
# MASTRA_MODEL=ollama:qwen2.5:3b

# --- Shared Mastra storage ---
# Default: file:<repo-root>/.mastra/mastra.db
# MASTRA_DB_URL=file:/absolute/path/to/mastra.db
# Note: file::memory:?cache=shared works for single-process dev but Studio + API won't share state
