{
  "name": "harness-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "api": "bun run --filter @harness/example-api dev",
    "console": "bun run --filter @harness/example-console dev",
    "web": "bun run api & bun run console",
    "studio:dev": "bunx mastra dev --config mastra.config.ts",
    "studio:build": "bunx mastra build --config mastra.config.ts",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "ci": "bun run lint && bun run typecheck && bun run build && bun test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "ai": "6.0.168",
    "lefthook": "2.1.6",
    "mastra": "1.6.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "3.0.53",
    "@mastra/core": "1.27.0",
    "@mastra/libsql": "1.9.0",
    "@mastra/memory": "1.17.0",
    "gpt-tokenizer": "3.4.0",
    "ollama-ai-provider-v2": "3.5.0"
  }
}
