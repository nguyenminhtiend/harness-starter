{
  "name": "harness-starter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "chat": "bun run --filter @harness/example-cli-chat dev",
    "research": "bun run --filter @harness/example-deep-research dev --",
    "server": "bun run --filter @harness/example-http-server dev",
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "eval": "bun run --filter @harness/cli dev -- eval",
    "ci": "bun run lint && bun run typecheck && bun run build && bun test",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@commitlint/types": "20.5.0",
    "lefthook": "2.1.6",
    "typescript": "^5.7.0"
  }
}
